# Gölgeli, yuvarlak köşeli kart bileşeni
def kart(icerik, padding=20, expand=False, bgcolor=None):
    return ft.Container(
        content=icerik,
        bgcolor=bgcolor or CARD,
        border_radius=20,
        padding=padding,
        border=ft.border.all(1.5, BORDER),
        shadow=ft.BoxShadow(
            spread_radius=0,
            blur_radius=16,
            color="#9D94B820",
            offset=ft.Offset(0, 4),
        ),
        expand=expand,
    )


# Genel metin bileşeni
def yazi(metin, boyut=13, renk=MUTED, kalinlik=ft.FontWeight.NORMAL):
    return ft.Text(metin, size=boyut, color=renk, weight=kalinlik)


def baslik(metin, boyut=20):
    return ft.Text(metin, size=boyut, color=TEXT, weight=ft.FontWeight.BOLD)


def buton(etiket, tikla, ikon=None, arkaplan=ACCENT, yazi_renk=WHITE, genislik=None):
    ogeler = []
    if ikon:
        ogeler.append(ft.Icon(ikon, size=15, color=yazi_renk))
    ogeler.append(ft.Text(etiket, size=13, color=yazi_renk, weight=ft.FontWeight.W_600))
    return ft.Container(
        content=ft.Row(ogeler, spacing=6, alignment=ft.MainAxisAlignment.CENTER),
        bgcolor=arkaplan,
        border_radius=14,
        padding=ft.padding.symmetric(horizontal=20, vertical=12),
        on_click=tikla,
        ink=True,
        width=genislik,
        shadow=ft.BoxShadow(
            spread_radius=0,
            blur_radius=10,
            color=arkaplan + "60" if arkaplan != SURFACE and arkaplan != CARD else "#00000010",
            offset=ft.Offset(0, 3),
        ),
    )


def metin_alani(etiket, ipucu="", ref=None, genislik=None):
    return ft.TextField(
        label=etiket,
        hint_text=ipucu,
        ref=ref,
        width=genislik,
        filled=True,
        fill_color="#F8F5FF",
        border_color=BORDER,
        focused_border_color=ACCENT,
        label_style=ft.TextStyle(color=MUTED, size=12),
        text_style=ft.TextStyle(color=TEXT, size=14),
        border_radius=14,
        cursor_color=ACCENT,
    )


def bildirim_goster(page, mesaj, renk=SUCCESS):
    page.snack_bar = ft.SnackBar(
        ft.Text(mesaj, color=WHITE),
        bgcolor=renk,
        behavior=ft.SnackBarBehavior.FLOATING,
        margin=20,
        duration=2500,
    )
    page.snack_bar.open = True
    page.update()


