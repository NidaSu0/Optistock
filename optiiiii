def sorgu(sql, params=()):
    """SELECT sorguları için; sonuçları dict listesi olarak döner."""
    con = sqlite3.connect(DB)
    con.row_factory = sqlite3.Row
    cur = con.cursor()
    cur.execute(sql, params)
    sonuc = cur.fetchall()
    con.close()
    return [dict(r) for r in sonuc]


# INSERT / UPDATE / DELETE işlemleri için
def calistir(sql, params=()):
    con = sqlite3.connect(DB)
    cur = con.cursor()
    cur.execute(sql, params)
    con.commit()
    son_id = cur.lastrowid
    con.close()
    return son_id


# Dashboard için özet istatistikleri çek
def istatistik_getir():
    ciro = sorgu("SELECT COALESCE(SUM(total),0) AS v FROM sales")[0]["v"]
    urun_sayisi = sorgu("SELECT COUNT(*) AS v FROM products")[0]["v"]
    musteri_sayisi = sorgu("SELECT COUNT(*) AS v FROM customers")[0]["v"]
    siparis_sayisi = sorgu("SELECT COUNT(*) AS v FROM sales")[0]["v"]
    return ciro, urun_sayisi, musteri_sayisi, siparis_sayisi


# Son 7 günün günlük ciro verisini çubuk grafik için hazırla
def son7gun():
    liste = []
    for i in range(6, -1, -1):
        gun = (datetime.datetime.now() - datetime.timedelta(days=i)).strftime("%Y-%m-%d")
        etiket = (datetime.datetime.now() - datetime.timedelta(days=i)).strftime("%d/%m")
        v = sorgu(
            "SELECT COALESCE(SUM(total),0) AS v FROM sales WHERE date LIKE ?",
            (gun + "%",)
        )[0]["v"]
        liste.append((etiket, float(v)))
    return liste


