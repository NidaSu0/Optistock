# Çubuk grafik — harici kütüphane kullanmadan sıfırdan yazıldı
def grafik_olustur(veri):
    degerler = [v for _, v in veri]
    en_buyuk = max(degerler) if max(degerler) > 0 else 1
    MAX_Y = 100
    BAR_W = 52

    cubuklar = []
    for idx, (etiket, deger) in enumerate(veri):
        yukseklik = max(4, int(MAX_Y * deger / en_buyuk))
        bugun_mu = idx == len(veri) - 1
        renk = SUCCESS if bugun_mu else ACCENT

        val_yazi = ft.Text(
            f"₺{deger/1000:.0f}K" if deger >= 1000 else f"₺{deger:.0f}",
            size=9, color=renk, weight=ft.FontWeight.W_600
        )

        cubuk = ft.Container(
            bgcolor=renk + "CC",
            width=BAR_W,
            height=yukseklik,
            border_radius=ft.border_radius.only(top_left=5, top_right=5),
        )

        gun_yazi = ft.Text(etiket, size=9, color=MUTED)

        sutun = ft.Column(
            controls=[
                ft.Container(height=MAX_Y - yukseklik),
                val_yazi,
                cubuk,
                gun_yazi,
            ],
            spacing=3,
            horizontal_alignment=ft.CrossAxisAlignment.CENTER,
        )
        cubuklar.append(sutun)

    return ft.Row(controls=cubuklar, spacing=10, alignment=ft.MainAxisAlignment.START)


