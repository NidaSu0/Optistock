        satirlar = [
            ft.DataRow(cells=[
                ft.DataCell(ft.Text(str(m["id"]), size=12, color=MUTED)),
                ft.DataCell(ft.Text(m["name"], size=13, color=TEXT, weight=ft.FontWeight.W_500)),
                ft.DataCell(ft.Text(m["email"] or "-", size=12, color=MUTED)),
                ft.DataCell(ft.Text(m["phone"] or "-", size=12, color=MUTED)),
                ft.DataCell(ft.Text(m["created"][:10] if m["created"] else "-", size=12, color=MUTED)),
            ]) for m in musteriler
        ]
        if not satirlar:
            satirlar = [ft.DataRow(cells=[
                ft.DataCell(ft.Text("Müşteri bulunamadı", color=MUTED)),
                ft.DataCell(ft.Text("")), ft.DataCell(ft.Text("")),
                ft.DataCell(ft.Text("")), ft.DataCell(ft.Text("")),
            ])]

        liste_ref.current.controls = [
            ft.DataTable(
                columns=[ft.DataColumn(ft.Text(s, size=13, color=MUTED))
                         for s in ["ID", "Ad Soyad", "E-posta", "Telefon", "Kayıt"]],
                rows=satirlar,
                border=ft.border.all(1, BORDER),
                border_radius=10,
                heading_row_color="#F3EEFF",
                data_row_color={ft.ControlState.HOVERED: "#F8F5FF"},
                expand=True,
            )
        ]
        page.update()

    def musteri_ekle(_):
        ad = ad_ref.current.value.strip()
        if not ad:
            bildirim_goster(page, "Müşteri adı boş olamaz!", DANGER)
            return
        calistir("INSERT INTO customers(name,email,phone) VALUES(?,?,?)",
                 (ad, eposta_ref.current.value.strip(), tel_ref.current.value.strip()))
        ad_ref.current.value = ""
        eposta_ref.current.value = ""
        tel_ref.current.value = ""
        bildirim_goster(page, f"'{ad}' müşterisi eklendi ✓")
        listeyi_yenile()

    tablo_col = ft.Column(ref=liste_ref, expand=True)
    listeyi_yenile()

    return ft.Column([
        baslik("👥  CRM — Müşteri Yönetimi", 24),
        ft.Divider(height=1, color=BORDER),
        kart(ft.Column([
            baslik("Yeni Müşteri Ekle", 16),
            ft.Row([
                metin_alani("Ad Soyad *", ref=ad_ref, genislik=220),
                metin_alani("E-posta", ref=eposta_ref, genislik=220),
                metin_alani("Telefon", ref=tel_ref, genislik=160),
                ft.Container(expand=True),
                buton("Ekle", musteri_ekle, ft.Icons.PERSON_ADD_ROUNDED, arkaplan=ACCENT2),
            ], spacing=12, vertical_alignment=ft.CrossAxisAlignment.END),
        ], spacing=12)),
        kart(tablo_col, padding=12, expand=True),
    ], spacing=16, expand=True, scroll=ft.ScrollMode.AUTO)


def satis_sayfasi(page):
    musteri_dd_ref = ft.Ref[ft.Dropdown]()
    urun_dd_ref = ft.Ref[ft.Dropdown]()
    adet_ref = ft.Ref[ft.TextField]()
    bilgi_ref = ft.Ref[ft.Text]()
    liste_ref = ft.Ref[ft.Column]()

    def musteri_secenekleri():
        return [ft.dropdown.Option(key=str(m["id"]), text=m["name"])
                for m in sorgu("SELECT id, name FROM customers ORDER BY name")]

    def urun_secenekleri():
        return [
            ft.dropdown.Option(
                key=str(u["id"]),
                text=f"{u['name']}  —  ₺{u['price']:,.2f}  (Stok: {u['stock']})"
            )
            for u in sorgu("SELECT id, name, price, stock FROM products ORDER BY name")
        ]

    def dropdown_yenile():
        musteri_dd_ref.current.options = musteri_secenekleri()
        urun_dd_ref.current.options = urun_secenekleri()
        page.update()

    def listeyi_yenile():
        veriler = sorgu("""
            SELECT s.id, s.date, c.name AS musteri_adi, p.name AS urun_adi,
                   s.quantity, s.total
            FROM sales s
            LEFT JOIN customers c ON c.id = s.customer_id
            LEFT JOIN products p ON p.id = s.product_id
            ORDER BY s.id DESC LIMIT 50
        """)
        satirlar = [
            ft.DataRow(cells=[
                ft.DataCell(ft.Text(str(r["id"]), size=12, color=MUTED)),
                ft.DataCell(ft.Text(r["date"][:16] if r["date"] else "-", size=12, color=MUTED)),
                ft.DataCell(ft.Text(r["musteri_adi"] or "-", size=13, color=TEXT)),
                ft.DataCell(ft.Text(r["urun_adi"] or "-", size=13, color=TEXT)),
                ft.DataCell(ft.Text(str(r["quantity"]), size=13, color=TEXT)),
                ft.DataCell(ft.Text(f"₺{r['total']:,.2f}", size=13, color=SUCCESS, weight=ft.FontWeight.W_600)),
            ]) for r in veriler
        ]
        if not satirlar:
            satirlar = [ft.DataRow(cells=[
                ft.DataCell(ft.Text("Satış bulunamadı", color=MUTED)),
                ft.DataCell(ft.Text("")), ft.DataCell(ft.Text("")),
                ft.DataCell(ft.Text("")), ft.DataCell(ft.Text("")),
                ft.DataCell(ft.Text("")),
            ])]

        liste_ref.current.controls = [
            ft.DataTable(
                columns=[ft.DataColumn(ft.Text(s, size=13, color=MUTED))
                         for s in ["#", "Tarih", "Müşteri", "Ürün", "Adet", "Toplam"]],
                rows=satirlar,
                border=ft.border.all(1, BORDER),
                border_radius=10,
                heading_row_color="#F3EEFF",
                data_row_color={ft.ControlState.HOVERED: "#F8F5FF"},
                expand=True,
            )
        ]
        page.update()

    def stok_bilgisi_goster(_):
        pid = urun_dd_ref.current.value
        if pid:
            r = sorgu("SELECT price, stock FROM products WHERE id=?", (int(pid),))
            if r:
                bilgi_ref.current.value = f"Birim Fiyat: ₺{r[0]['price']:,.2f}   |   Mevcut Stok: {r[0]['stock']}"
                page.update()

    def satisi_tamamla(_):
        cid = musteri_dd_ref.current.value
        pid = urun_dd_ref.current.value
        if not cid or not pid:
            bildirim_goster(page, "Müşteri ve ürün seçiniz!", DANGER)
            return
        try:
            adet = int(adet_ref.current.value or 0)
            if adet <= 0:
                raise ValueError
        except ValueError:
            bildirim_goster(page, "Geçerli bir adet girin!", DANGER)
            return

        urun = sorgu("SELECT price, stock FROM products WHERE id=?", (int(pid),))
        if not urun:
            bildirim_goster(page, "Ürün bulunamadı!", DANGER)
            return

        fiyat = urun[0]["price"]
        stok = urun[0]["stock"]

        if adet > stok:
            bildirim_goster(page, f"Yetersiz stok! Mevcut: {stok}", DANGER)
            return

        toplam = fiyat * adet
        calistir(
            "INSERT INTO sales(customer_id,product_id,quantity,total) VALUES(?,?,?,?)",
            (int(cid), int(pid), adet, toplam)
        )
        calistir("UPDATE products SET stock = stock - ? WHERE id=?", (adet, int(pid)))

        adet_ref.current.value = ""
        bilgi_ref.current.value = ""
        bildirim_goster(page, f"Satış tamamlandı ✓  Toplam: ₺{toplam:,.2f}")
        dropdown_yenile()
        listeyi_yenile()

    tablo_col = ft.Column(ref=liste_ref, expand=True)

    musteri_dd = ft.Dropdown(
        ref=musteri_dd_ref,
        label="Müşteri Seç",
        options=musteri_secenekleri(),
        width=240,
        filled=True,
        fill_color="#F8F5FF",
        border_color=BORDER,
        focused_border_color=ACCENT,
        label_style=ft.TextStyle(color=MUTED, size=12),
        text_style=ft.TextStyle(color=TEXT, size=13),
        border_radius=14,
    )

    urun_dd = ft.Dropdown(
        ref=urun_dd_ref,
        label="Ürün Seç",
        options=urun_secenekleri(),
        width=360,
        filled=True,
        fill_color="#F8F5FF",
        border_color=BORDER,
        focused_border_color=ACCENT,
        label_style=ft.TextStyle(color=MUTED, size=12),
        text_style=ft.TextStyle(color=TEXT, size=13),
        border_radius=14,
    )

    listeyi_yenile()

    return ft.Column([
        baslik("🛒  Satış İşlemi", 24),
        ft.Divider(height=1, color=BORDER),
        kart(ft.Column([
            baslik("Yeni Satış", 16),
            ft.Row([
                musteri_dd,
                urun_dd,
                metin_alani("Adet *", "1", ref=adet_ref, genislik=100),
                buton("Stok Kontrol", stok_bilgisi_goster, ft.Icons.SEARCH_ROUNDED, arkaplan=SURFACE),
                ft.Container(expand=True),
                buton("Satışı Tamamla", satisi_tamamla,
                      ft.Icons.SHOPPING_CART_CHECKOUT_ROUNDED,
                      arkaplan=SUCCESS, yazi_renk="#0D0F18"),
            ], spacing=12, vertical_alignment=ft.CrossAxisAlignment.END),
            ft.Text(ref=bilgi_ref, size=12, color=ACCENT),
        ], spacing=12)),
        kart(tablo_col, padding=12, expand=True),
    ], spacing=16, expand=True, scroll=ft.ScrollMode.AUTO)


# Ana uygulama fonksiyonu
def main(page: ft.Page):
    page.title = "OptiStock — Stok & CRM Yönetimi  |  Nida Subaşı  |  2026"
    page.bgcolor = BG
    page.padding = 0
    page.theme_mode = ft.ThemeMode.LIGHT
    page.window_width = 1340
    page.window_height = 820

    aktif_sayfa = {"v": "dashboard"}
    icerik = ft.Column(expand=True, scroll=ft.ScrollMode.AUTO)
    nav_sutun = ft.Column(spacing=4)

    def sayfa_git(anahtar):
        aktif_sayfa["v"] = anahtar
        navbari_yenile()
        sayfayi_yukle(anahtar)

    def sayfayi_yukle(anahtar):
        sayfalar = {
            "dashboard": lambda: dashboard_sayfasi(page, sayfa_git),
            "products": lambda: stok_sayfasi(page),
            "customers": lambda: musteri_sayfasi(page),
            "sales": lambda: satis_sayfasi(page),
        }
        icerik.controls = [
            ft.Container(sayfalar[anahtar](), expand=True, padding=ft.padding.all(24))
        ]
        page.update()

    def nav_ogesi(ikon, etiket, anahtar):
        def tikla(_): sayfa_git(anahtar)
        aktif = aktif_sayfa["v"] == anahtar
        return ft.Container(
            ft.Row([
                ft.Icon(ikon, size=18, color=ACCENT if aktif else MUTED),
                ft.Text(etiket, size=13,
                        color=TEXT if aktif else MUTED,
                        weight=ft.FontWeight.W_600 if aktif else ft.FontWeight.NORMAL),
            ], spacing=10),
            bgcolor=ACCENT + "18" if aktif else "transparent",
            border_radius=12,
            padding=ft.padding.symmetric(10, 14),
            on_click=tikla,
            ink=True,
        )

    def navbari_yenile():
        nav_sutun.controls = [
            nav_ogesi(ft.Icons.DASHBOARD_ROUNDED, "Dashboard", "dashboard"),
            nav_ogesi(ft.Icons.INVENTORY_2_ROUNDED, "Stok", "products"),
            nav_ogesi(ft.Icons.PEOPLE_ALT_ROUNDED, "Müşteriler", "customers"),
            nav_ogesi(ft.Icons.SHOPPING_CART_ROUNDED, "Satış", "sales"),
        ]
        page.update()

    kenar_cubugu = ft.Container(
        ft.Column([
            ft.Container(
                ft.Row([
                    ft.Container(
                        ft.Text("OS", size=12, color=WHITE, weight=ft.FontWeight.BOLD),
                        bgcolor=ACCENT,
                        border_radius=12,
                        padding=ft.padding.symmetric(horizontal=10, vertical=7),
                    ),
                    ft.Column([
                        ft.Text("OptiStock", size=14, color=TEXT, weight=ft.FontWeight.BOLD),
                        ft.Text("v1.0.0", size=10, color=MUTED),
                    ], spacing=0),
                ], spacing=10),
                padding=ft.padding.only(left=14, top=20, bottom=14),
            ),
            ft.Divider(height=1, color=BORDER),
            ft.Container(nav_sutun, padding=ft.padding.symmetric(8, 10)),
            ft.Container(expand=True),
            ft.Divider(height=1, color=BORDER),
            ft.Container(
                ft.Column([
                    ft.Row([
                        ft.Icon(ft.Icons.CIRCLE, color=SUCCESS, size=8),
                        ft.Text("Sistem aktif", size=11, color=MUTED),
                    ], spacing=6),
                    ft.Container(height=4),
                    ft.Text("by Nida Subaşı  |  2026", size=10, color=ACCENT, weight=ft.FontWeight.W_600),
                ], spacing=0),
                padding=ft.padding.all(14),
            ),
        ], spacing=0, expand=True),
        width=210,
        bgcolor=SURFACE,
        border=ft.border.only(right=ft.BorderSide(1.5, BORDER)),
        shadow=ft.BoxShadow(
            spread_radius=0,
            blur_radius=20,
            color="#9D94B825",
            offset=ft.Offset(4, 0),
        ),
    )

    navbari_yenile()
    sayfayi_yukle("dashboard")

    page.add(
        ft.Row([
            kenar_cubugu,
            ft.Container(icerik, expand=True, bgcolor=BG),
        ], expand=True, spacing=0)
    )


if __name__ == "__main__":
    # Veritabanını başlat ve uygulamayı çalıştır
