def stok_sayfasi(page):
    ad_ref = ft.Ref[ft.TextField]()
    fiyat_ref = ft.Ref[ft.TextField]()
    stok_ref = ft.Ref[ft.TextField]()
    kategori_ref = ft.Ref[ft.TextField]()
    liste_ref = ft.Ref[ft.Column]()

    def listeyi_yenile():
        urunler = sorgu("SELECT * FROM products ORDER BY id DESC")
        satirlar = []
        for u in urunler:
            if u["stock"] <= 5:
                stok_renk = DANGER
            elif u["stock"] <= 20:
                stok_renk = WARNING
            else:
                stok_renk = SUCCESS

            satirlar.append(ft.DataRow(cells=[
                ft.DataCell(ft.Text(str(u["id"]), size=12, color=MUTED)),
                ft.DataCell(ft.Text(u["name"], size=13, color=TEXT, weight=ft.FontWeight.W_500)),
                ft.DataCell(ft.Text(u["category"] or "-", size=12, color=MUTED)),
                ft.DataCell(ft.Text(f"₺{u['price']:,.2f}", size=13, color=ACCENT, weight=ft.FontWeight.W_600)),
                ft.DataCell(ft.Container(
                    ft.Text(str(u["stock"]), size=13, color=stok_renk, weight=ft.FontWeight.BOLD),
                    bgcolor=stok_renk + "22",
                    border_radius=6,
                    padding=ft.padding.symmetric(4, 10),
                )),
            ]))

        if not satirlar:
            satirlar = [ft.DataRow(cells=[
                ft.DataCell(ft.Text("Ürün bulunamadı", color=MUTED)),
                ft.DataCell(ft.Text("")), ft.DataCell(ft.Text("")),
                ft.DataCell(ft.Text("")), ft.DataCell(ft.Text("")),
            ])]

        liste_ref.current.controls = [
            ft.DataTable(
                columns=[ft.DataColumn(ft.Text(s, size=13, color=MUTED))
                         for s in ["ID", "Ürün Adı", "Kategori", "Fiyat", "Stok"]],
                rows=satirlar,
                border=ft.border.all(1, BORDER),
                border_radius=10,
                heading_row_color="#F3EEFF",
                data_row_color={ft.ControlState.HOVERED: "#F8F5FF"},
                expand=True,
            )
        ]
        page.update()

    def urun_ekle(_):
        ad = ad_ref.current.value.strip()
        if not ad:
            bildirim_goster(page, "Ürün adı boş olamaz!", DANGER)
            return
        try:
            fiyat = float(fiyat_ref.current.value or 0)
            stok = int(stok_ref.current.value or 0)
        except ValueError:
            bildirim_goster(page, "Fiyat ve stok sayı olmalı!", DANGER)
            return

        kategori = kategori_ref.current.value.strip()
        calistir("INSERT INTO products(name,price,stock,category) VALUES(?,?,?,?)",
                 (ad, fiyat, stok, kategori))

        ad_ref.current.value = ""
        fiyat_ref.current.value = ""
        stok_ref.current.value = ""
        kategori_ref.current.value = ""

        bildirim_goster(page, f"'{ad}' ürünü eklendi ✓")
        listeyi_yenile()

    tablo_col = ft.Column(ref=liste_ref, expand=True)
    listeyi_yenile()

    return ft.Column([
        baslik("📦  Stok Yönetimi", 24),
        ft.Divider(height=1, color=BORDER),
        kart(ft.Column([
            baslik("Yeni Ürün Ekle", 16),
            ft.Row([
                metin_alani("Ürün Adı *", ref=ad_ref, genislik=240),
                metin_alani("Fiyat (₺)", "0.00", ref=fiyat_ref, genislik=140),
                metin_alani("Stok", "0", ref=stok_ref, genislik=120),
                metin_alani("Kategori", ref=kategori_ref, genislik=160),
                ft.Container(expand=True),
                buton("Ekle", urun_ekle, ft.Icons.ADD_ROUNDED),
            ], spacing=12, vertical_alignment=ft.CrossAxisAlignment.END),
        ], spacing=12)),
        kart(tablo_col, padding=12, expand=True),
    ], spacing=16, expand=True, scroll=ft.ScrollMode.AUTO)


